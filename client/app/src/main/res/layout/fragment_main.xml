<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".fragments.Main">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.163"
            app:layout_constraintWidth_percent="0.7" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use your phone as a mouse &amp; keyboard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.496"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView2"
            app:layout_constraintVertical_bias="0.0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnectBT"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_alignStart="@id/textView2"
            android:layout_alignEnd="@id/textView2"
            android:layout_centerHorizontal="true"
            android:backgroundTint="#000000"
            android:padding="20dp"
            android:text="Bluetooth"
            android:textColor="#c9c9c9"
            android:textSize="18sp"
            app:cornerRadius="10dp"
            app:icon="@drawable/baseline_bluetooth_24"
            app:iconGravity="textStart"
            app:iconSize="26sp"
            app:iconTint="#ffffff"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnPairBT"
            app:layout_constraintHorizontal_bias="0.862"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView2"
            app:layout_constraintVertical_bias="0.368"
            app:layout_constraintWidth_percent="0.5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPairBT"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginEnd="56dp"
            android:backgroundTint="#000000"
            android:padding="20dp"
            android:text="Pair"
            android:textColor="#c9c9c9"
            android:textSize="18sp"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toTopOf="@+id/btnConnectSV"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView2"
            app:layout_constraintVertical_bias="0.94"
            app:layout_constraintWidth_percent="0.2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnectSV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/textView2"
            android:layout_alignStart="@id/textView2"
            android:layout_alignEnd="@id/textView2"
            android:layout_centerHorizontal="true"
            android:backgroundTint="#000000"
            android:padding="20dp"
            android:text="Server (USB/WIFI)"
            android:textColor="#c9c9c9"
            android:textSize="18sp"
            app:cornerRadius="10dp"
            app:icon="@drawable/usb"
            app:iconGravity="textStart"
            app:iconSize="26sp"
            app:iconTint="#ffffff"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.512"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnConnectBT"
            app:layout_constraintVertical_bias="0.046"
            app:layout_constraintWidth_percent="0.72" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>